<section id="contacto" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-gray-900 rounded-[3rem] overflow-hidden shadow-2xl">
      <div class="grid lg:grid-cols-2">
        <div class="p-12 lg:p-16">
          <h2 class="text-3xl font-extrabold text-white mb-6">Solicita tu cotización</h2>
          <p class="text-gray-400 mb-8 max-w-md">Déjanos tus datos y un especialista se pondrá en contacto contigo en menos de 24 horas.</p>
          
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Nombre o Empresa</label>
              <input type="text" id="name" class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-shadow" placeholder="Escribe tu nombre">
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-300 mb-2">Teléfono</label>
              <input type="tel" id="phone" class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-shadow" placeholder="Tu número de celular">
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-gray-300 mb-2">Servicio</label>
              <select id="service" class="w-full bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-shadow">
                <option>Venta de Extintores</option>
                <option>Recarga y Mantenimiento</option>
                <option>Señaléticas de Seguridad</option>
                <option>Otros</option>
              </select>
            </div>
            <button type="button" class="w-full bg-red-600 text-white font-bold py-4 rounded-xl hover:bg-red-700 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-0.5">
              Enviar Solicitud
            </button>
          </form>
        </div>
        
        <div class="relative hidden lg:block">
          <img src="https://images.unsplash.com/photo-1582216091350-019b88ef574c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Soporte técnico de extintores" class="absolute inset-0 w-full h-full object-cover">
          <div class="absolute inset-0 bg-gradient-to-r from-gray-900 to-transparent"></div>
        </div>
      </div>
    </div>
  </div>
</section>
